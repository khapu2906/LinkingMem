# ============================================================
# AI Graph Engine — Environment Configuration
# ============================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Loading priority (highest wins):
#   1. Actual environment variables (export FOO=bar)
#   2. .env file (loaded by Docker Compose / dotenv)
#   3. Built-in defaults shown here
#
# Plugin endpoints are configured separately in plugins.toml
# (see PLUGIN_CONFIG_FILE below).
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------

# Address and port the engine HTTP server listens on.
BIND_ADDR=0.0.0.0:8000

# Log level. Supports per-module filters, e.g.:
#   info,ai_graph_engine=debug
RUST_LOG=info

# ------------------------------------------------------------
# Data
# ------------------------------------------------------------

# Directory containing graph.bin, vectors.bin, delta.wal.
# Must be writable (delta store and WAL write here).
#
# Default (no need to set unless you want a custom location):
#   - production binary : <dir containing binary>/data/
#   - cargo run         : <project root>/data/
#
# Examples:
#   DATA_DIR=./data
#   DATA_DIR=/var/lib/ai-graph-engine/data
DATA_DIR=./data

# ------------------------------------------------------------
# Plugin config file
# ------------------------------------------------------------

# Path to plugins.toml — describes how to reach each plugin.
# Can be absolute or relative to the working directory.
#
# Default (no need to set unless you want a custom location):
#   - production binary : <dir containing binary>/plugins.toml
#   - cargo run         : <project root>/plugins.toml
#
# Examples:
#   PLUGIN_CONFIG_FILE=./plugins.toml
#   PLUGIN_CONFIG_FILE=/etc/ai-graph-engine/plugins.toml
PLUGIN_CONFIG_FILE=./plugins.toml

# Fallback: if a plugin is not defined in plugins.toml,
# all three endpoints (embed / extract / generate) will use
# this single URL. Ignored when plugins.toml is present.
PLUGIN_URL=http://localhost:8001

# ------------------------------------------------------------
# Cache
# ------------------------------------------------------------

# Maximum number of embedding vectors to keep in memory.
# Each entry ≈ dim × 4 bytes (384-dim → ~1.5 KB per entry).
EMBED_CACHE_SIZE=50000

# Maximum number of full query results to cache.
QUERY_CACHE_SIZE=10000

# How long a cached query result is valid, in seconds.
QUERY_CACHE_TTL_SECS=300

# ------------------------------------------------------------
# Delta store
# ------------------------------------------------------------

# Trigger an async graph/HNSW rebuild when the delta buffer
# accumulates this many new nodes + edges.
DELTA_MERGE_THRESHOLD=500

# Instance identifier for distributed deployments (0–255).
# Used to partition the node-ID space: node_id = (INSTANCE_ID << 24) | local_seq
# Ensures no collision when multiple instances share the same WAL directory.
# Default: 0 (single-instance deployments need not set this).
INSTANCE_ID=0

# ------------------------------------------------------------
# Query pipeline tuning
# ------------------------------------------------------------

# ------------------------------------------------------------
# Multi-hop query tuning
# ------------------------------------------------------------

# Default maximum reasoning iterations for POST /query/multihop.
# Overridable per-request via the max_hops field (1–5).
MULTIHOP_DEFAULT_MAX_HOPS=2

# ------------------------------------------------------------
# Query pipeline tuning
# ------------------------------------------------------------

# Number of seed nodes retrieved by HNSW vector search.
# Higher = more recall, slower search. Range: 5–200.
HNSW_K=20

# BFS expansion depth from seed nodes.
# 1 = direct neighbors only, 2 = neighbors-of-neighbors, etc.
BFS_DEPTH=2

# Max nodes collected during BFS expansion.
BFS_MAX_NODES=500

# Top-N highest-scored nodes passed as context to the LLM.
CONTEXT_TOP_N=50

# Minimum relevance score to include a node in LLM context.
# Nodes scoring below this are dropped. Range: 0.0–1.0.
CONTEXT_MIN_SCORE=0.3

# ------------------------------------------------------------
# Entity resolution (ingest)
# ------------------------------------------------------------

# How to resolve new entities against existing graph nodes.
# "embedding" — cosine similarity (default), "none" — disable.
RESOLUTION_MODE=embedding

# Cosine similarity threshold for embedding-based resolution.
# Increase to be stricter (fewer merges), decrease for more.
RESOLUTION_THRESHOLD=0.92

# If true, entities must share the same type to be merged.
RESOLUTION_MATCH_TYPE=false

# ------------------------------------------------------------
# Plugin — connection timeouts
# ------------------------------------------------------------

# TCP connect timeout to the plugin server (seconds).
PLUGIN_CONNECT_TIMEOUT_SECS=5

# Per-operation request timeouts (seconds).
# Embed is fast; extract/generate involve LLM calls and can be slow.
PLUGIN_EMBED_TIMEOUT_SECS=30
PLUGIN_EXTRACT_TIMEOUT_SECS=60
PLUGIN_GENERATE_TIMEOUT_SECS=120
PLUGIN_HEALTH_TIMEOUT_SECS=3

# ------------------------------------------------------------
# Plugin — auth
# ------------------------------------------------------------

# Bearer token the Rust engine sends to the plugin server.
# Set the same value as PLUGIN_AUTH_TOKEN in the plugin server's environment.
# Leave empty (or unset) to disable plugin auth (safe for unix socket deployments).
# Example: PLUGIN_EMBED_AUTH_TOKEN=my-secret
# Note: auth_token can also be set per-plugin in plugins.toml.

# ------------------------------------------------------------
# Plugin server — auth (set on the plugin server side)
# ------------------------------------------------------------

# If set, the plugin server requires "Authorization: Bearer <token>" on all requests.
# Leave empty to disable auth checking (e.g. when using unix socket transport).
PLUGIN_AUTH_TOKEN=

# ------------------------------------------------------------
# Plugin — AI models
# ------------------------------------------------------------

# Embedding model (sentence-transformers — any model name is accepted).
# Built-in supported options:
#   all-MiniLM-L6-v2       (default, 22 MB, English, fast)
#   BAAI/bge-small-en-v1.5 (384-dim, high quality, English)
#   thenlper/gte-small      (384-dim, high quality, English)
#   BAAI/bge-m3             (1024-dim, multilingual, best quality, large)
EMBED_MODEL=all-MiniLM-L6-v2

# Embedding throughput tuning (plugin server side).
# Sentences per inference batch. Larger = higher throughput, more memory.
EMBED_BATCH_SIZE=32
# Max simultaneous encode calls. Prevents CPU spike under high concurrency.
EMBED_MAX_CONCURRENCY=4
# Set to "0" to skip model warmup on startup (useful for dev/testing).
EMBED_WARMUP=1

# Max concurrent LLM calls across /extract and /generate (plugin server side).
# Each call may block a thread; keep this ≤ your LLM provider's rate limit.
LLM_MAX_CONCURRENCY=8

# LLM model for /extract and /generate.
# Format: "provider/model-name"
# Provider is inferred from the prefix — no separate LLM_PROVIDER needed.
#
# Supported providers and example models:
#   google/gemini-2.5-flash-lite      (default, fast + cheap)
#   google/gemini-2.0-flash
#   openai/gpt-4o-mini
#   openai/gpt-4o
#   anthropic/claude-haiku-4-5-20251001
#   anthropic/claude-sonnet-4-6
#
# Extract and generate can use different providers:
#   EXTRACT_MODEL=openai/gpt-4o-mini
#   GENERATE_MODEL=anthropic/claude-sonnet-4-6

EXTRACT_MODEL=google/gemini-2.5-flash-lite
GENERATE_MODEL=google/gemini-2.5-flash-lite

# API keys — only the key for your chosen provider(s) is required.
GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=    # optional: Ollama or other OpenAI-compatible APIs
# ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Auth
# ------------------------------------------------------------

# Comma-separated list of valid API keys.
# Leave empty (or unset) to disable authentication entirely.
# Example: API_KEYS=key-abc123,key-def456
API_KEYS=

# Rate limiting per API key.
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
